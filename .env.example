# Added by Payload
PAYLOAD_SECRET=xxx
POSTGRESQL_ADDON_URI=postgres://user:password@localhost:5434/maisondelautisme-site

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_SECRET=""

# Better Auth GitHub OAuth
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""

# Open API
OPENAI_API_KEY=xx

# Albert
ALBERT_API_KEY=xxx
ALBERT_API_URL=https://albert.api.etalab.gouv.fr

# OpenAI (used for semantic search embeddings)
OPENAI_API_KEY=xxx

# AWS S3 configuration
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_REGION=eu-west-3
S3_BUCKET=maisondelautisme

# HTTP WWW Authenticate temporary preprod
BASIC_USER=xxx
BASIC_PASSWORD=xxx

# SMTP (email sending via @payloadcms/email-nodemailer)
# Local dev defaults point to maildev from docker-compose (http://localhost:1080)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=contact@maisondelautisme.gouv.fr
SMTP_FROM_NAME=Maison de l'autisme

# Destinataire du formulaire "Contact professionnels CRA"
CONTACT_PROS_CRA_RECIPIENT=contact@maisondelautisme.gouv.fr