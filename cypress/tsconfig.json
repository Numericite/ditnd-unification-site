{
	"compilerOptions": {
		"target": "es2022",
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"isolatedModules": false,
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["cypress", "node"]
	},
	"include": ["**/*.ts"]
}
